# ── Firebase Web SDK config ──────────────────────────────────────────
# Copy this file to .env.local and fill in your actual values from Firebase Console

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=kingstonconnect.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=kingstonconnect
VITE_FIREBASE_STORAGE_BUCKET=kingstonconnect.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── FCM VAPID Key (from Firebase Console → Project Settings → Cloud Messaging) ──
VITE_FIREBASE_VAPID_KEY=your-vapid-key-here

# ── Cloud Functions encryption key (32-byte hex, required for Gemini API key encryption) ──
AES_KEY=replace_with_64_hex_chars
