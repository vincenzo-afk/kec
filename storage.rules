rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — owner can write, authenticated users can read
    match /profile-photos/{userId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Notes — authenticated + approved users
    match /notes/{dept}/{year}/{section}/{subject}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;
    }

    // Timetables
    match /timetables/{dept}/{year}/{section}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;
    }

    // Leave attachments
    match /leave-attachments/{leaveId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Achievement images
    match /achievement-images/{achievementId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Event attachments
    match /event-attachments/{eventId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;
    }

    // Announcement attachments
    match /announcements/{announcementId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;
    }

    // Temp cache — readable/writable by all authenticated
    match /temp-cache/{filename} {
      allow read, write: if request.auth != null;
    }
  }
}
