# ── Firebase Web SDK config ──────────────────────────────────────────
# Copy this file to .env.local and fill in your actual values from Firebase Console

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── FCM VAPID Key (from Firebase Console → Project Settings → Cloud Messaging) ──
VITE_FIREBASE_VAPID_KEY=

# Local emulator mode is opt-in.
# Keep these false if you want to use your live Firebase project during `npm run dev`.
VITE_USE_EMULATORS=false
VITE_USE_STORAGE_EMULATOR=false
VITE_USE_FUNCTIONS_EMULATOR=false
VITE_EMULATOR_HOST=127.0.0.1
VITE_AUTH_EMULATOR_PORT=9099
VITE_FIRESTORE_EMULATOR_PORT=8080
VITE_STORAGE_EMULATOR_PORT=9199
VITE_FUNCTIONS_EMULATOR_PORT=5001

# ── Cloud Functions encryption key (32-byte hex, required for Gemini API key encryption) ──
AES_KEY=
